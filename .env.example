# Copy this file to .env and fill in your key.
# main.py and server.py will refuse to start without OPENAI_API_KEY set.

OPENAI_API_KEY=sk-your-key-here

# --- Optional overrides (defaults shown) ---
# DEEPWAVE_CLASSIFIER_MODEL=gpt-4o-mini
# DEEPWAVE_PLANNER_MODEL=gpt-4o-mini
# DEEPWAVE_REWRITER_MODEL=gpt-4o
# DEEPWAVE_CRITIC_MODEL=gpt-4o
# DEEPWAVE_CONFIDENCE_THRESHOLD=0.75
# DEEPWAVE_MAX_ITERATIONS=3
# DEEPWAVE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# DEEPWAVE_DEBUG=false